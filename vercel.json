{
  "version": 2,
  "routes": [
    { "src": "/api/auth(.*)",     "dest": "/api/auth.js"     },
    { "src": "/api/products(.*)", "dest": "/api/products.js" },
    { "src": "/api/orders(.*)",   "dest": "/api/orders.js"   },
    { "src": "/api/messages(.*)", "dest": "/api/messages.js" },
    { "src": "/api/payment(.*)",  "dest": "/api/payment.js"  },
    { "src": "/api/users(.*)",    "dest": "/api/users.js"    },
    { "src": "/(.*)",             "dest": "/public/$1"       }
  ]
}
