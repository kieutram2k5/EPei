# ============================================
# EPei - Environment Variables
# Copy file này thành .env và điền vào
# ============================================

# MySQL (Railway hoặc PlanetScale)
MYSQL_HOST=your-host.railway.app
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your-password
MYSQL_DATABASE=epei_db

# Hoặc dùng DATABASE_URL (Railway cung cấp)
# DATABASE_URL=mysql://user:password@host:port/database

# JWT Secret (đổi thành chuỗi random dài)
JWT_SECRET=epei_super_secret_key_change_this

# SSL (Railway cần true, localhost = false)
DB_SSL=false

# Frontend URL (cho CORS)
FRONTEND_URL=https://your-app.vercel.app
